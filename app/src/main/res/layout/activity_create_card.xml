<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/poolrooms_bg"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Card"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/poolrooms_text"
            android:layout_marginBottom="24dp"/>

        <!-- card name input -->
        <!-- campo de nombre de carta -->
        <EditText
            android:id="@+id/etCardName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Card name"
            android:inputType="text"
            android:layout_marginBottom="16dp"/>

        <!-- rarity label and spinner -->
        <!-- etiqueta y spinner de rareza -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rarity"
            android:textColor="@color/poolrooms_text"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerRarity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- category label and spinner -->
        <!-- etiqueta y spinner de categoria -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="@color/poolrooms_text"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"/>

        <!-- image preview, shows card back until the user picks an image -->
        <!-- vista previa de imagen, muestra el reverso hasta que el usuario elija una imagen -->
        <ImageView
            android:id="@+id/ivPreview"
            android:layout_width="160dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@drawable/card_back"
            android:layout_marginBottom="12dp"/>

        <!-- button that opens the system photo picker -->
        <!-- boton que abre el selector de fotos del sistema -->
        <Button
            android:id="@+id/btnPickImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pick Image"
            android:layout_marginBottom="24dp"/>

        <!-- save button commits everything to the database -->
        <!-- el boton guardar confirma todo a la base de datos -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Card"
            android:layout_marginBottom="8dp"/>

        <!-- cancel button closes without saving -->
        <!-- el boton cancelar cierra sin guardar -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancel"/>

    </LinearLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/poolrooms_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BACKROOMS TCG"
        android:textColor="@color/poolrooms_text"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A trading card game based on the Backrooms universe.\nOpen packs, collect cards, and build your own custom collection.\n\nVersion 1.0"
        android:textColor="@color/poolrooms_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:fontFamily="monospace"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/acceptButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Accept"
        android:backgroundTint="@color/poolrooms_button"/>

</LinearLayout>
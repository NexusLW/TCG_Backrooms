<?xml version="1.0" encoding="utf-8"?>
<!--using a FrameLayout so we can overlay the count badge on top of the card image-->
<!--usando FrameLayout para poder superponer la insignia de cantidad sobre la imagen-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp"
    android:background="@color/poolrooms_surface">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="120dp">

        <!--card image-->
        <!--imagen de la carta-->
        <ImageView
            android:id="@+id/ivCard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>

        <!--count badge, only visible when count is more than 1-->
        <!--insignia de cantidad, solo visible cuando el count es mayor a 1-->
        <TextView
            android:id="@+id/tvCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:background="@color/poolrooms_button"
            android:textColor="@color/poolrooms_text"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone"
            android:text="x2"/>

    </FrameLayout>

    <!--card name-->
    <TextView
        android:id="@+id/tvCardName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="???"
        android:textColor="@color/poolrooms_text"
        android:textSize="10sp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingTop="4dp"/>

    <!--rarity label-->
    <TextView
        android:id="@+id/tvRarity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="???"
        android:textSize="9sp"
        android:gravity="center"
        android:paddingBottom="4dp"/>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Backrooms TCG"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.NoActionBar">

        <!--login is the entry point of the app-->
        <!--el login es el punto de entrada de la app-->
        <activity android:name=".LoginActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!--main screen with the two tabs-->
        <!--pantalla principal con las dos pestanas-->
        <activity android:name=".MainActivity" android:exported="false"/>

        <!--fullscreen card detail, opened when tapping an unlocked card-->
        <!--detalle de carta en pantalla completa, se abre al tocar una carta desbloqueada-->
        <activity android:name=".CardDetailActivity" android:exported="false"/>

        <activity android:name=".CreateCardActivity" android:exported="false"/>

        <activity android:name=".AboutActivity" android:exported="false"/>

        <activity android:name=".SettingsActivity" android:exported="false"/>
    </application>

</manifest>